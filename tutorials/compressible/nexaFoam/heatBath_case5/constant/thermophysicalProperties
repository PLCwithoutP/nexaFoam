FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      thermophysicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

thermoType
{
    type            heNe2TReactionThermo;
    mixture         neReactingMixture;
    transport       blottnerEucken2T;
    thermo          janaf2T;
    equationOfState perfect2TGas;
    specie          specie2T;
    energy          sensibleCalculation2T;
}

twoTemperature      false;
VVrelaxation        false;
chemistry           true;

chemistryReader     foamNeChemistryReader;

reactionsList           "<constant>/reactionsDict";
speciesList             "<constant>/speciesDict";

