FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

libs 
(
    "libneTCLib_2T.so"
);

application     nexaFoam;

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime         1e-03;

deltaT          1e-09;

writeControl    runTime;

writeInterval   1e-09;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

graphFormat     raw;

runTimeModifiable true;

adjustTimeStep  no;

maxCo           0.2;

maxDeltaT       1e-02;

