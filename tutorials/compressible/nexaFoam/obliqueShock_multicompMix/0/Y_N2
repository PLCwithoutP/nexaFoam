FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      Y_N2;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

#include "initialConditions"

dimensions      [0 0 0 0 0 0 0];

internalField   uniform $N2_mol_fraction;

boundaryField
{
    top
    {
        type            fixedValue;
        value           uniform $N2_mol_fraction;
    }

    inlet
    {
        type            fixedValue;
        value           uniform $N2_mol_fraction;
    }

    outlet
    {
        type            zeroGradient;
    }

    bottom
    {
        type            symmetryPlane;
    }

    frontAndBack
    {
        type            empty;
    }
}


